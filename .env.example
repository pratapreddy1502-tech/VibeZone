SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TLS=true

# PostgreSQL connection used by FastAPI.
DATABASE_URL=postgresql://postgres:1502@localhost/VIBEZONE
SECRET_KEY=change-this-to-a-long-random-production-secret
CORS_ORIGINS=*

# Optional. Default is ./uploads.
# Use this to store reel/photo files on another disk or server folder.
VIBEZONE_STORAGE_DIR=C:\VibeZoneStorage

# Optional production media storage. When set, uploads go to Supabase Storage
# instead of the local uploads folder.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=vibezone-media
SUPABASE_PUBLIC_BUCKET=true

# Expo app production backend URL. Set this before creating a dev build.
EXPO_PUBLIC_API_BASE_URL=https://vibezone-mwg7.onrender.com
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_USE_LOCAL_API=false

# Set EXPO_PUBLIC_USE_LOCAL_API=true only when testing FastAPI on this laptop.
# Phone APK builds should keep it false so they use the online Render backend.

# Optional WebRTC ICE servers for voice/video calls.
# Default uses Google STUN. Add a TURN server for reliable calls across strict mobile networks.
# Comma-separated form:
# EXPO_PUBLIC_WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302,turn:your-turn-host:3478
# JSON form with credentials:
# EXPO_PUBLIC_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:your-turn-host:3478","username":"user","credential":"pass"}]
EXPO_PUBLIC_WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
