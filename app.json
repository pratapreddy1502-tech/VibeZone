{
  "expo": {
    "name": "VibeZone",
    "slug": "VibeZone",
    "version": "1.0.0",
    "scheme": "vibezone",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibezone.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow VibeZone to use your microphone for live voice calls.",
        "NSCameraUsageDescription": "Allow VibeZone to use your camera for video calls."
      }
    },
    "android": {
      "package": "com.vibezone.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH_CONNECT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-video",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow VibeZone to unlock private chats with Face ID."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d2c6af96-0825-444d-bff7-a3f7ea44d7bd"
      }
    }
  }
}
